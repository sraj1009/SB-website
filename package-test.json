{
  "name": "singglebee-tests",
  "version": "1.0.0",
  "description": "Critical test suite for SINGGLEBEE launch readiness",
  "main": "tests/setup.js",
  "scripts": {
    "test": "NODE_ENV=test vitest run --reporter=verbose",
    "test:watch": "NODE_ENV=test vitest --watch",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "test:critical": "NODE_ENV=test vitest run tests/critical-flows.test.js",
    "test:security": "NODE_ENV=test vitest run tests/security.test.js",
    "test:payment": "NODE_ENV=test vitest run tests/payment.test.js",
    "test:api": "NODE_ENV=test vitest run tests/api.test.js",
    "test:all": "npm run test:critical && npm run test:security && npm run test:payment && npm run test:api",
    "test:load": "NODE_ENV=test vitest run tests/load.test.js",
    "test:integration": "NODE_ENV=test vitest run tests/integration.test.js",
    "test:e2e": "NODE_ENV=test playwright test",
    "test:smoke": "NODE_ENV=test node tests/smoke-test.js",
    "test:performance": "NODE_ENV=test node tests/performance-test.js",
    "test:security:scan": "npm audit && npm run test:injection && npm run test:xss",
    "test:injection": "node tests/security/injection-test.js",
    "test:xss": "node tests/security/xss-test.js",
    "test:penetration": "node tests/security/penetration-test.js",
    "test:payment:gateway": "node tests/payment/gateway-test.js",
    "test:payment:webhook": "node tests/payment/webhook-test.js",
    "test:payment:failure": "node tests/payment/failure-test.js",
    "test:database": "node tests/database/connection-test.js",
    "test:redis": "node tests/database/redis-test.js",
    "test:monitoring": "node tests/monitoring/health-test.js",
    "test:jwt": "node tests/security/jwt-test.js",
    "test:rate-limit": "node tests/security/rate-limit-test.js",
    "test:csrf": "node tests/security/csrf-test.js",
    "pretest": "npm run setup:test-db",
    "posttest": "npm run cleanup:test-db",
    "setup:test-db": "node scripts/setup-test-db.js",
    "cleanup:test-db": "node scripts/cleanup-test-db.js",
    "test:parallel": "NODE_ENV=test vitest run --run --threads",
    "test:sequential": "NODE_ENV=test vitest run --run --no-threads",
    "test:report": "NODE_ENV=test vitest run --reporter=html --outputFile=test-report.html",
    "test:json": "NODE_ENV=test vitest run --reporter=json --outputFile=test-results.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@supertest/request": "^6.3.3",
    "@types/supertest": "^2.0.16",
    "artillery": "^2.0.0",
    "artillery-plugin-websocket": "^1.0.0",
    "chai": "^4.3.10",
    "chai-http": "^4.4.0",
    "faker": "^6.6.6",
    "frisby": "^2.1.3",
    "jest": "^29.7.0",
    "k6": "^0.47.0",
    "mocha": "^10.2.0",
    "nock": "^13.4.0",
    "nyc": "^15.1.0",
    "playwright": "^1.40.0",
    "sinon": "^17.0.1",
    "supertest": "^6.3.3",
    "vitest": "^1.0.4",
    "webdriverio": "^8.24.12",
    "ws": "^8.14.2"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^9.1.6",
    "redis-memory-server": "^0.10.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "testing",
    "security",
    "payment",
    "api",
    "integration",
    "e2e",
    "load",
    "performance"
  ],
  "author": "SINGGLEBEE Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/singglebee/singglebee-tests.git"
  },
  "bugs": {
    "url": "https://github.com/singglebee/singglebee-tests/issues"
  },
  "homepage": "https://singglebee.com",
  "vitest": {
    "testTimeout": 30000,
    "hookTimeout": 10000,
    "globalSetup": "./tests/setup.js",
    "globalTeardown": "./tests/teardown.js",
    "environment": "node",
    "coverage": {
      "provider": "v8",
      "reporter": ["text", "html", "json"],
      "exclude": [
        "node_modules/",
        "tests/",
        "scripts/",
        "coverage/",
        "**/*.test.js",
        "**/*.spec.js"
      ],
      "thresholds": {
        "global": {
          "branches": 80,
          "functions": 80,
          "lines": 80,
          "statements": 80
        },
        "critical": {
          "branches": 95,
          "functions": 95,
          "lines": 95,
          "statements": 95
        }
      }
    },
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "include": [
      "tests/**/*.{test,spec}.{js,ts}",
      "server/**/*.{test,spec}.{js,ts}"
    ],
    "exclude": [
      "node_modules/",
      "dist/",
      "coverage/"
    ]
  },
  "jest": {
    "testTimeout": 30000,
    "setupFilesAfterEnv": ["./tests/setup.js"],
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "server/**/*.js",
      "src/**/*.js",
      "!server/**/*.test.js",
      "!src/**/*.test.js",
      "!node_modules/**",
      "!coverage/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "mocha": {
    "timeout": 30000,
    "recursive": true,
    "spec": "tests/**/*.test.js",
    "require": [
      "tests/setup.js"
    ]
  },
  "nyc": {
    "include": [
      "server/**/*.js",
      "src/**/*.js"
    ],
    "exclude": [
      "server/**/*.test.js",
      "src/**/*.test.js",
      "node_modules/**",
      "coverage/**"
    ],
    "reporter": [
      "text",
      "html",
      "json"
    ],
    "threshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
