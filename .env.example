# Frontend Environment Variables Example
# Copy to .env and fill in values. Note: Vite requires VITE_ prefix for client-exposed vars.

# API base URL (used by api-client.ts)
VITE_API_BASE_URL=http://localhost:5000/api/v1
# Legacy alias
VITE_API_URL=http://localhost:5000/api/v1
VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_CASHFREE_ENV=sandbox
VITE_APP_NAME=SINGGLEBEE
VITE_APP_DESCRIPTION="Premium Marketplace"
