# Server Environment Variables
# Copy this file to .env and fill in the values

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/singglebee

# JWT Secrets (Generate strong random strings for production)
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cashfree Payment Gateway
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_API_VERSION=2023-08-01
CASHFREE_ENV=sandbox

# UPI Details (Fallback)
UPI_ID=singglebee.rsventures@okhdfcbank

# Backend URL (for Cashfree Webhooks - must match your server URL)
BACKEND_URL=http://localhost:5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Admin Seed (Only used for initial setup - change in production!)
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_strong_password_min_8_chars

# Rate Limiting
RATELIMIT_WINDOW_MS=900000
RATELIMIT_MAX=100

# Security
COOKIE_SECRET=use_a_strong_random_string
SECURE_COOKIES=true

# Email (optional - for password reset & order confirmation)
# Option A: SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key
# Option B: SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@singglebee.com
# SMTP_PASS=your_smtp_password
# EMAIL_FROM=noreply@singglebee.com
